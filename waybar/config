{
  "layer": "top",
  "position": "top",
  "height": 24,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["backlight", "custom/system", "pulseaudio", "battery", "network", "tray"],
  "hyprland/workspaces": {"disable-scroll": true, "all-outputs": true, "persistent-workspaces": {"*": 5}},
  "clock": {"format": "{:%I:%M %p %a %e}"},
  "backlight": {"format": "☼ {percent}%"},
  "pulseaudio": {"format": "♪ {volume}%", "tooltip": false},
  "battery": {"format": "BATT {capacity}%", "states": {"good": 95, "warning": 30, "critical": 15}},
  "network": {"format-wifi": "⌁ {essid} {signalStrength}%", "format-ethernet": "⌁ Ethernet", "format-disconnected": "Wifi (disconnected)"},
  "custom/system": {"exec": "~/forge/waybar/system-stats.sh", "interval": 5},
  "tray": {"spacing": 8}
}
